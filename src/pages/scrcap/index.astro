---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../utils/seo";
import editorScreenshot from "../../assets/scrcap/editor-light.png";
import appIcon from "../../assets/scrcap/app-icon.png";

const canonicalUrl = "https://scrcap.kubre.in/";
const releaseUrl = "https://github.com/kubre/scrcap/releases/latest";
const sourceUrl = "https://github.com/kubre/scrcap";
const screenshotUrl = new URL(editorScreenshot.src, canonicalUrl).href;
const appIconUrl = new URL(appIcon.src, canonicalUrl).href;
const description =
    "scrcap is a tiny, keyboard-first macOS screenshot app for region, window, fullscreen, and scrolling captures with fast annotation and PNG export.";

const stack = ["macOS 14+", "Native macOS app"];

const modes = [
    {
        glyph: "▢",
        title: "Region",
        body: "Crosshair coordinates, mid-drag move, Esc to abort.",
        keys: ["⌥", "⇧", "1"],
    },
    {
        glyph: "❐",
        title: "Window",
        body: "Hover highlight, cycle through overlapping windows.",
        keys: ["⌥", "⇧", "2"],
    },
    {
        glyph: "⛶",
        title: "Fullscreen",
        body: "Grab the whole display under the cursor.",
        keys: ["⌥", "⇧", "3"],
    },
    {
        glyph: "↧",
        title: "Scrolling",
        body: "Select, scroll, and stitch into one tall image.",
        keys: ["⌥", "⇧", "4"],
    },
    {
        glyph: "◷",
        title: "Delayed",
        body: "Select a region, then a countdown before the shot fires.",
        keys: ["⌥", "⇧", "5"],
    },
    {
        glyph: "↺",
        title: "Repeat last",
        body: "Re-grab the same region, window, or screen instantly.",
        keys: ["⌥", "⇧", "R"],
    },
];

const editorKeys = [
    { keys: ["Q", "W", "E", "R", "T", "Y"], label: "Arrow / rect / counter / text / pixelate / crop" },
    { keys: ["1", "–", "5"], label: "Color shortcuts" },
    { keys: ["Z", "X", "C"], label: "Small / medium / large size" },
    { keys: ["Esc"], label: "Copy to clipboard and close" },
    { keys: ["⌘", "C"], label: "Copy, keep editor open" },
    { keys: ["⌘", "S"], label: "Save PNG to folder" },
    { keys: ["⇧", "⌘", "S"], label: "Save as…" },
];

const stats = [
    { value: "< 1 MB", label: "App bundle" },
    { value: "0", label: "Electron shells" },
    { value: "14+", label: "macOS version" },
];

const structuredData = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "WebPage",
            "@id": canonicalUrl,
            url: canonicalUrl,
            name: "scrcap - macOS screenshot tool",
            description,
            isPartOf: {
                "@type": "WebSite",
                name: SITE.name,
                url: SITE.url,
            },
            about: { "@id": `${canonicalUrl}#software` },
            primaryImageOfPage: {
                "@type": "ImageObject",
                url: screenshotUrl,
                caption: "The scrcap editor with annotation tools and a bottom toolbar",
            },
            inLanguage: "en",
            datePublished: "2026-06-12",
            dateModified: "2026-06-13",
            author: {
                "@type": "Person",
                name: "Vaibhav Kubre",
                url: SITE.url,
            },
        },
        {
            "@type": "SoftwareApplication",
            "@id": `${canonicalUrl}#software`,
            name: "scrcap",
            alternateName: "screen capture",
            description,
            url: canonicalUrl,
            image: [appIconUrl, screenshotUrl],
            screenshot: screenshotUrl,
            applicationCategory: "UtilitiesApplication",
            operatingSystem: "macOS 14+",
            softwareVersion: "v0",
            fileSize: "< 1 MB app bundle",
            downloadUrl: releaseUrl,
            installUrl: releaseUrl,
            codeRepository: sourceUrl,
            programmingLanguage: "Swift",
            offers: {
                "@type": "Offer",
                price: 0,
                priceCurrency: "USD",
                url: releaseUrl,
                availability: "https://schema.org/InStock",
            },
            creator: {
                "@type": "Person",
                name: "Vaibhav Kubre",
                url: SITE.url,
            },
            featureList: [
                "Region screenshot capture",
                "Window screenshot capture",
                "Fullscreen screenshot capture",
                "Scrolling screenshot capture",
                "Delayed region capture",
                "Repeat last capture",
                "Screenshot annotation editor with pixelate / redaction",
                "Clipboard, PNG save, and drag-out export",
                "Remappable keyboard shortcuts",
            ],
        },
    ],
};
---

<BaseLayout
    title="scrcap - macOS screenshot tool"
    description={description}
    ogImage={screenshotUrl}
    canonicalUrl={canonicalUrl}
>
    <meta
        slot="head"
        name="robots"
        content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"
    />
    <meta slot="head" name="application-name" content="scrcap" />
    <meta slot="head" name="author" content="Vaibhav Kubre" />
    <meta slot="head" property="og:logo" content={appIconUrl} />
    <meta slot="head" property="product:brand" content="scrcap" />
    <meta slot="head" property="product:category" content="macOS screenshot tool" />
    <link slot="head" rel="alternate" type="text/markdown" href="/llms.txt" title="LLM context" />
    <script
        slot="head"
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(structuredData)}
    />

    <main class="py-8 md:py-12">
        <!-- Hero -->
        <header class="grid gap-6 border-b-2 border-carbon pb-10">
            <div class="flex items-center gap-4 md:gap-6">
                <Image
                    src={appIcon}
                    alt="scrcap app icon"
                    width={128}
                    height={128}
                    class="h-20 w-20 md:h-28 md:w-28"
                    loading="eager"
                    decoding="async"
                />
                <div>
                    <h1
                        class="font-mono text-5xl font-black uppercase leading-none text-carbon md:text-7xl"
                    >
                        scrcap
                    </h1>
                    <p
                        class="mt-2 font-mono text-xs uppercase tracking-[0.2em] text-carbon-lighter"
                    >
                        Screenshot, marked up, done.
                    </p>
                </div>
            </div>

            <div class="flex flex-wrap gap-2">
                {
                    stack.map((item) => (
                        <span class="border-2 border-carbon px-2 py-[2px] font-mono text-xs uppercase text-carbon">
                            {item}
                        </span>
                    ))
                }
            </div>

            <p class="max-w-2xl font-sans text-base leading-7 text-black md:text-lg">
                scrcap (screen capture) is a lightweight macOS app that lets you take a screenshot,
                annotate it, and drop it on your clipboard superfast.
            </p>

            <div class="flex flex-col gap-3 sm:flex-row">
                <a
                    href={releaseUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="border-2 border-carbon bg-carbon px-4 py-2 text-center font-mono text-sm uppercase text-white transition-colors hover:bg-yellow-400 hover:text-black"
                >
                    ↓ Download latest release
                </a>
                <a
                    href={sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="border-2 border-carbon px-4 py-2 text-center font-mono text-sm uppercase text-carbon transition-colors hover:bg-carbon hover:text-white"
                >
                    View source
                </a>
            </div>
        </header>

        <!-- Hero screenshot framed as a capture marquee -->
        <section class="py-8 md:py-10">
            <figure class="relative border-2 border-carbon bg-white p-2">
                <div class="marquee-handle -left-[6px] -top-[6px]"></div>
                <div class="marquee-handle -right-[6px] -top-[6px]"></div>
                <div class="marquee-handle -bottom-[6px] -left-[6px]"></div>
                <div class="marquee-handle -bottom-[6px] -right-[6px]"></div>
                <Image
                    src={editorScreenshot}
                    alt="The scrcap editor with annotation tools and a bottom toolbar"
                    sizes="(max-width: 768px) 100vw, 768px"
                    format="webp"
                    quality={80}
                    class="h-auto w-full"
                    loading="eager"
                    decoding="async"
                />
                <figcaption
                    class="absolute bottom-3 right-3 bg-carbon px-2 py-[2px] font-mono text-[11px] text-white"
                >
                    ⌖ 587 × 318
                </figcaption>
            </figure>
        </section>

        <!-- Capture modes (each with its default shortcut) -->
        <section class="py-8">
            <h2 class="mb-1 font-mono text-xs uppercase tracking-[0.2em] text-carbon-lighter">
                ▚ Capture modes
            </h2>
            <div class="mt-4 grid gap-px border-2 border-carbon bg-carbon md:grid-cols-2">
                {
                    modes.map((mode) => (
                        <div class="flex flex-col bg-enamel p-5">
                            <div class="flex items-baseline gap-3">
                                <span class="font-mono text-2xl leading-none text-carbon">
                                    {mode.glyph}
                                </span>
                                <h3 class="font-mono text-lg uppercase text-carbon">
                                    {mode.title}
                                </h3>
                            </div>
                            <p class="mt-2 font-sans text-sm leading-6 text-black">{mode.body}</p>
                            <div class="mt-3 flex h-6 items-center gap-1">
                                {mode.keys ? (
                                    mode.keys.map((k) => (
                                        <kbd class="inline-flex min-w-[1.75rem] items-center justify-center border-2 border-b-4 border-carbon bg-white px-1.5 py-0.5 font-mono text-xs text-carbon">
                                            {k}
                                        </kbd>
                                    ))
                                ) : (
                                    <span class="font-mono text-xs uppercase text-carbon-lightest">
                                        Assign in Preferences
                                    </span>
                                )}
                            </div>
                        </div>
                    ))
                }
            </div>
            <p class="mt-4 font-sans text-sm leading-6 text-carbon-lighter">
                Defaults shown. Every capture shortcut is remappable in
                <span class="text-carbon">Preferences</span>.
            </p>
        </section>

        <!-- The editor: prose + shortcuts side by side -->
        <section class="grid gap-8 py-8 md:grid-cols-2">
            <div>
                <h2 class="font-mono text-xl uppercase text-carbon">A direct editor</h2>
                <p class="mt-3 font-sans leading-7 text-black">
                    The current tool stays armed, so drawing another arrow or rectangle never means
                    switching back from a selection mode. Pixelate anything sensitive, pick a size,
                    and undo if a mark is wrong.
                </p>
                <p class="mt-3 font-sans leading-7 text-black">
                    When you're done, copy to the clipboard, save the PNG to your folder, or
                    Option-drag the flattened image straight into another app.
                </p>
            </div>
            <div>
                <h3 class="font-mono text-xs uppercase tracking-[0.2em] text-carbon-lighter">
                    ⌨ In the editor
                </h3>
                <dl class="mt-4 grid gap-3">
                    {
                        editorKeys.map((row) => (
                            <div class="flex items-center gap-3">
                                <dt class="flex shrink-0 gap-1">
                                    {row.keys.map((k) => (
                                        <kbd class="inline-flex min-w-[2rem] items-center justify-center border-2 border-b-4 border-carbon bg-white px-2 py-1 font-mono text-sm text-carbon">
                                            {k}
                                        </kbd>
                                    ))}
                                </dt>
                                <dd class="font-sans text-sm leading-6 text-black">{row.label}</dd>
                            </div>
                        ))
                    }
                </dl>
            </div>
        </section>

        <!-- Make it yours -->
        <section class="py-8">
            <div class="border-2 border-carbon bg-white p-5 md:p-6">
                <h2 class="font-mono text-xl uppercase text-carbon">Make it yours</h2>
                <p class="mt-3 max-w-2xl font-sans leading-7 text-black">
                    The defaults are just a starting point. Open
                    <span class="bg-yellow-400 px-1 text-black">Preferences</span> to remap every capture
                    shortcut, change the annotation colors, set the capture delay, and choose your save
                    location and export behavior.
                </p>
            </div>
        </section>

        <!-- By the numbers -->
        <section class="py-8">
            <div class="grid grid-cols-1 gap-px border-2 border-carbon bg-carbon sm:grid-cols-3">
                {
                    stats.map((stat) => (
                        <div class="bg-carbon px-4 py-6 text-center">
                            <p class="font-mono text-3xl font-black text-white md:text-4xl">
                                {stat.value}
                            </p>
                            <p class="mt-1 font-mono text-xs uppercase tracking-wide text-carbon-lightest">
                                {stat.label}
                            </p>
                        </div>
                    ))
                }
            </div>
            <p class="mt-4 max-w-2xl font-sans text-sm leading-6 text-carbon-lighter">
                A native app with no Electron shell and no runtime framework bundle. The release
                build is stripped and size-optimized to stay tiny.
            </p>
        </section>

        <!-- Install -->
        <section class="border-t-2 border-carbon py-8">
            <h2 class="font-mono text-xl uppercase text-carbon">Install</h2>
            <ol class="mt-4 grid gap-3">
                <li class="flex gap-3 font-sans leading-7 text-black">
                    <span class="font-mono text-carbon-lighter">01</span>
                    <span
                        >Download <code class="bg-enamel-dark px-1">scrcap-macos.dmg</code> from the latest
                        GitHub Release.</span
                    >
                </li>
                <li class="flex gap-3 font-sans leading-7 text-black">
                    <span class="font-mono text-carbon-lighter">02</span>
                    <span
                        >Open the DMG and drag <code class="bg-enamel-dark px-1">scrcap.app</code> to
                        Applications.</span
                    >
                </li>
                <li class="flex gap-3 font-sans leading-7 text-black">
                    <span class="font-mono text-carbon-lighter">03</span>
                    <span
                        >Launch it. The first capture asks for Screen Recording; scrolling capture
                        asks for Accessibility only when you use it.</span
                    >
                </li>
            </ol>
            <p
                class="mt-5 border-l-2 border-carbon bg-enamel-dark px-3 py-2 font-sans text-sm leading-6 text-black"
            >
                Not notarized by Apple yet, so macOS may ask you to approve it from
                <code>System Settings → Privacy &amp; Security</code> the first time you open it.
            </p>
            <a
                href={releaseUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-block border-2 border-carbon bg-carbon px-4 py-2 font-mono text-sm uppercase text-white transition-colors hover:bg-yellow-400 hover:text-black"
            >
                ↓ Download scrcap
            </a>
        </section>

        <footer
            class="flex flex-col gap-2 border-t-2 border-carbon py-6 text-sm sm:flex-row sm:items-center sm:justify-between"
        >
            <p class="font-mono text-carbon-lighter">
                made by <a href="/" class="underline hover:bg-yellow-400 hover:text-black"
                    >kubre.in</a
                >
            </p>
            <a
                href={sourceUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-carbon-lighter underline hover:bg-yellow-400 hover:text-black"
            >
                GitHub
            </a>
        </footer>
    </main>
</BaseLayout>

<style>
    .marquee-handle {
        position: absolute;
        width: 12px;
        height: 12px;
        background-color: #e02323;
        z-index: 10;
    }
</style>
