---
import BaseLayout from "./BaseLayout.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import { DATE_FORMATTERS } from "../utils/date";
import { Image } from "astro:assets";
import { getOgImageUrl } from "../utils/seo";
import type { ImageMetadata } from "astro";

export interface Props {
    frontmatter: {
        title: string;
        description: string;
        image: ImageMetadata;
        hideHeaderImage?: boolean;
        publishedAt: Date;
        tags: string[];
        readTime: number;
    };
}

const { frontmatter } = Astro.props;
const url = Astro.url;
const backUrl = "/" + url.pathname.split("/")[1];
const ogImage = getOgImageUrl(frontmatter.image);
---

<BaseLayout
    title={frontmatter.title}
    description={frontmatter.description}
    ogImage={ogImage}
    ogType="article"
>
    <a
        href="#main"
        class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-carbon focus:text-enamel focus:px-3 focus:py-1"
        >Skip to content</a
    >
    <Nav />
    <main id="main">
        <article class="pt-10 typography font-sans">
            <div class="flex justify-between items-center">
                <a
                    href={backUrl}
                    class="text-carbon-lighter font-mono hover:bg-yellow-400 hover:text-black transition-colors"
                >
                    ← Back
                </a>
                <dl>
                    <dt class="sr-only">Date</dt>
                    <dd
                        class="whitespace-nowrap not-prose pl-0 leading-6 font-mono text-sm text-carbon-lighter uppercase"
                    >
                        <time datetime={frontmatter.publishedAt.toISOString()}>
                            {DATE_FORMATTERS.full.format(frontmatter.publishedAt)}
                        </time>
                    </dd>
                </dl>
            </div>
            <h1 class="font-mono uppercase text-2xl text-carbon-lighter">
                {frontmatter.title}
            </h1>
            {
                !frontmatter.hideHeaderImage && (
                    <figure>
                        <Image
                            src={frontmatter.image}
                            width={768}
                            sizes="(max-width: 768px) 100vw, 768px"
                            format="webp"
                            quality={76}
                            loading="eager"
                            fetchpriority="high"
                            decoding="async"
                            alt={frontmatter.title}
                            class="w-full h-auto p-4"
                        />
                    </figure>
                )
            }
            <section>
                <slot />
            </section>
            <section id="comments-section" class="giscus mx-auto my-10 max-w-screen-md">
                <button
                    id="load-comments"
                    class="font-mono border border-carbon px-3 py-1 hover:bg-yellow-400 hover:text-black transition-colors"
                >
                    Load comments
                </button>
                <div id="comments-root" class="mt-4"></div>
            </section>
            <script>
                const commentsSection = document.getElementById("comments-section");
                const commentsRoot = document.getElementById("comments-root");
                const loadCommentsButton = document.getElementById("load-comments");

                const loadComments = () => {
                    if (!commentsRoot || commentsRoot.dataset.loaded === "true") {
                        return;
                    }

                    const giscus = document.createElement("script");
                    giscus.src = "https://giscus.app/client.js";
                    giscus.async = true;
                    giscus.crossOrigin = "anonymous";
                    giscus.setAttribute("data-repo", "kubre/kubre.in");
                    giscus.setAttribute("data-repo-id", "R_kgDOIK6Pcg");
                    giscus.setAttribute("data-category", "Comments");
                    giscus.setAttribute("data-category-id", "DIC_kwDOIK6Pcs4CUdUh");
                    giscus.setAttribute("data-mapping", "pathname");
                    giscus.setAttribute("data-strict", "0");
                    giscus.setAttribute("data-reactions-enabled", "1");
                    giscus.setAttribute("data-emit-metadata", "0");
                    giscus.setAttribute("data-input-position", "bottom");
                    giscus.setAttribute("data-theme", "light");
                    giscus.setAttribute("data-lang", "en");
                    giscus.setAttribute("data-loading", "lazy");

                    commentsRoot.dataset.loaded = "true";
                    commentsRoot.appendChild(giscus);
                    loadCommentsButton?.remove();
                };

                loadCommentsButton?.addEventListener("click", loadComments);

                if (commentsSection && "IntersectionObserver" in window) {
                    const observer = new IntersectionObserver(
                        (entries) => {
                            if (entries.some((entry) => entry.isIntersecting)) {
                                loadComments();
                                observer.disconnect();
                            }
                        },
                        { rootMargin: "200px" },
                    );

                    observer.observe(commentsSection);
                }
            </script>
            <Footer />
        </article>
    </main>
</BaseLayout>
